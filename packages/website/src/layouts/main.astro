---
import { ClientRouter } from "astro:transitions";
import { perspectiveCookieName } from "@sanity/preview-url-secret/constants";
import "../styles/global.css";

import { resolveSiteSettingsData } from "../sanity/resolvers";

import SanityVisualEditing from "../components/sanity/sanity-visual-editing";
import DisableDraftMode from "../components/sanity/disable-draft-mode";
import Nav from "../components/nav.astro";
import Footer from "../components/footer.astro";

const draftMode = Astro.cookies.has(perspectiveCookieName);
const data = await resolveSiteSettingsData(Astro.cookies);

const { siteName, mainNav, siteTagline } = data;
---

<html class="scroll-pt-26" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- TODO: Remove this when live -->
    <meta name="robots" content="noindex, nofollow" />
    <title>{siteName}</title>
    <ClientRouter />
  </head>
  <body class="bg-white">
    <Nav siteName={siteName} navItems={mainNav} />
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer
      siteName={siteName}
      siteTagline={siteTagline || ""}
      navItems={mainNav}
    />
    {
      draftMode && (
        <>
          <SanityVisualEditing client:only="react" />
          <DisableDraftMode client:only="react" />
        </>
      )
    }
  </body>
</html>
