---
import { ClientRouter } from "astro:transitions";
import { perspectiveCookieName } from "@sanity/preview-url-secret/constants";
import "../styles/global.css";

import SanityVisualEditing from "../components/sanity/sanity-visual-editing";
import DisableDraftMode from "../components/sanity/disable-draft-mode";
import Nav from "../components/nav.astro";
import Footer from "../components/footer.astro";
import type { SiteSettings } from "../types/sanity";

interface Props {
  title?: string | null;
  seo?: { metaTitle: string | null; metaDescription: string | null } | null;
  siteSettings: SiteSettings;
}

const draftMode = Astro.cookies.has(perspectiveCookieName);

const { seo, title, siteSettings } = Astro.props;
const { siteName, mainNav, siteTagline, mainSeo } = siteSettings;

const metaTitle =
  seo?.metaTitle ||
  (title ? `${title} | ${siteName}` : null) ||
  mainSeo?.metaTitle ||
  siteName;
---

<html class="scroll-pt-26" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={seo?.metaDescription || mainSeo?.metaDescription}
    />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{metaTitle}</title>
    <ClientRouter />
  </head>
  <body class="bg-white">
    <Nav siteName={siteName} navItems={mainNav} />
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer
      siteName={siteName}
      siteTagline={siteTagline || ""}
      navItems={mainNav}
    />
    {
      draftMode && (
        <>
          <SanityVisualEditing client:only="react" />
          <DisableDraftMode client:only="react" />
        </>
      )
    }
  </body>
</html>
