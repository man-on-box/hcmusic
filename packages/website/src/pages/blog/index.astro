---
import MainLayout from "../../layouts/main.astro";
import Section from "../../components/section.astro";
import BlockRenderer from "../../blocks/block-renderer.astro";
import BlogArticleCard from "../../components/blog-article-card.astro";

import { resolveBlogsPageData } from "../../sanity/resolvers";
import { hrefResolver } from "../../utils/link-resolver";

const { siteSettings, pageBuilder, articles, title, seo } =
  await resolveBlogsPageData(Astro.cookies);
---

<MainLayout siteSettings={siteSettings} title={title} seo={seo}>
  {pageBuilder && <BlockRenderer blocks={pageBuilder} />}

  <Section>
    <ol>
      {
        articles.map((article) => {
          return (
            <li class="border-t-2 border-slate-200 py-12 first:border-t-0 first:pt-0 sm:py-8">
              <a href={hrefResolver(article._type, article.slug)}>
                <BlogArticleCard article={article} />
              </a>
            </li>
          );
        })
      }
    </ol>
  </Section>
</MainLayout>
