---
import { formatDate } from "../../utils";
import { urlFor } from "../../sanity/image";
import {
  resolveBlogArticlesData,
  resolveBlogArticleData,
} from "../../sanity/resolvers";

import MainLayout from "../../layouts/main.astro";
import TextBlock from "../../blocks/text-block.astro";
import Hero from "../../components/hero.astro";

export async function getStaticPaths() {
  const data = await resolveBlogArticlesData();
  return data.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}
const { slug } = Astro.params;
const { page: initialData } = Astro.props;

const page = initialData ?? (await resolveBlogArticleData(Astro.cookies, slug));
const {
  siteSettings,
  title,
  articleDate,
  description,
  featureImage,
  articleContent,
} = page;

const date = new Date(articleDate ?? "");
const formattedDate = formatDate(date);
const dateString = `${formattedDate.day} ${formattedDate.month} ${formattedDate.year}`;
const seo = { metaTitle: null, metaDescription: description };
---

<MainLayout siteSettings={siteSettings} title={title} seo={seo}>
  <Hero
    heading={title || ""}
    subheading={dateString}
    imgSrc={featureImage
      ? urlFor(featureImage).width(1200).height(900).format("webp").url()
      : ""}
    imgAlt={featureImage?.asset?.altText || ""}
  />
  {articleContent && <TextBlock blockData={articleContent} />}
</MainLayout>
