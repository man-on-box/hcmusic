---
import type { PortableTextBlock } from "@portabletext/types";

import MainLayout from "../layouts/main.astro";
import BlockRenderer from "../blocks/block-renderer.astro";

import EventsList from "../components/events-list.astro";

import { resolveEventsPageData } from "../sanity/resolvers";

const { events, eventsPage } = await resolveEventsPageData(Astro.cookies);
const { pageBuilder, title, seo } = eventsPage;

const mappedEvents = events.map((event) => ({
  title: event.title || "no title",
  date: event.eventDatetime || "",
  location: event.location || "no location",
  description: event.description as PortableTextBlock[],
}));

const now = new Date();
const upcomingEvents = mappedEvents
  .filter((event) => event.date && new Date(event.date) >= now)
  .reverse();

const pastEvents = mappedEvents.filter(
  (event) => event.date && new Date(event.date) < now,
);
---

<MainLayout title={title} seo={seo}>
  {pageBuilder && <BlockRenderer blocks={pageBuilder} />}
  <EventsList heading="Upcoming events" events={upcomingEvents} />
  <EventsList heading="Past events" events={pastEvents} />
</MainLayout>
