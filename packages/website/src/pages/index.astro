---
import MainLayout from "../layouts/main.astro";
import BlockRenderer from "../blocks/block-renderer.astro";
import { resolveHomepageData } from "../sanity/resolvers";

const { pageBuilder, siteSettings } = await resolveHomepageData(Astro.cookies);
---

<MainLayout siteSettings={siteSettings}>
  {pageBuilder && <BlockRenderer blocks={pageBuilder} />}
</MainLayout>
