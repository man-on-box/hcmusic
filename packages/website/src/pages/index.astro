---
import { homepageQuery } from "../sanity/queries";
import MainLayout from "../layouts/main.astro";
import Prose from "../components/prose.astro";
import BlockRenderer from "../blocks/block-renderer.astro";

const { pageBuilder, features } = await homepageQuery();
---

<MainLayout>
  {pageBuilder && <BlockRenderer blocks={pageBuilder} />}
  <section class="bg-gray-800 py-16">
    <div class="mx-auto max-w-7xl">
      <Prose class="prose-invert mx-auto text-center">
        <h2>{features?.heading}</h2>
      </Prose>
      <div class="grid gap-8 md:grid-cols-3 lg:gap-10">
        {
          features?.cards?.map((card) => {
            return (
              <div>
                <p>{card.title}</p>
                <p>{card.description}</p>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>
</MainLayout>
