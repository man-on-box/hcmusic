---
import { PortableText } from "astro-portabletext";
import { linkMap } from "../config/links";

import { homepageQuery, urlFor } from "../queries";
import MainLayout from "../layouts/main.astro";
import Hero from "../components/hero.astro";
import Prose from "../components/prose.astro";
import LinkButton from "../components/link-button.astro";

const { heading, subheading, poster, about, features } = await homepageQuery();
---

<MainLayout>
  <Hero
    heading={heading ?? "Default heading"}
    subheading={subheading ?? "Default subheading"}
    imgSrc={poster ? urlFor(poster).width(1200).format("webp").url() : ""}
    imgAlt={poster?.alt || ""}
    variant="large"
  />
  <section class="flex flex-col items-center py-16">
    <Prose class="mb-12 text-center">
      <h2 class="mt-0">{about?.heading}</h2>
      {about?.blurb && <PortableText value={about?.blurb} />}
    </Prose>
    <LinkButton href={linkMap.bio}>{about?.cta}</LinkButton>
  </section>
  <section class="bg-gray-800 py-16">
    <div class="mx-auto max-w-7xl">
      <Prose class="prose-invert mx-auto text-center">
        <h2>{features?.heading}</h2>
      </Prose>
      <div class="grid gap-8 md:grid-cols-3 lg:gap-10">
        {
          features?.cards?.map((card) => {
            return (
              <div>
                <p>{card.title}</p>
                <p>{card.description}</p>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>
</MainLayout>
