---
import {
  resolveProjectsData,
  resolveProjectData,
} from "../../sanity/resolvers";
import MainLayout from "../../layouts/main.astro";
import BlockRenderer from "../../blocks/block-renderer.astro";

export async function getStaticPaths() {
  const pages = await resolveProjectsData();
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { slug } = Astro.params;
const { page: initialData } = Astro.props;

const page = initialData ?? (await resolveProjectData(Astro.cookies, slug));
const { pageBuilder, title, seo } = page;
---

<MainLayout title={title} seo={seo}>
  {pageBuilder && <BlockRenderer blocks={pageBuilder} />}
</MainLayout>
