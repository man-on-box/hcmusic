---
import { projectsQuery, projectQuery } from "../../sanity/queries";
import MainLayout from "../../layouts/main.astro";
import BlockRenderer from "../../blocks/block-renderer.astro";

export async function getStaticPaths() {
  const pages = await projectsQuery();

  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

let { page } = Astro.props;

if (!page) {
  const { slug } = Astro.params;
  if (slug) {
    page = await projectQuery(slug);
  }
}

if (!page) {
  Astro.response.status = 404;
  Astro.response.statusText = "Not found";
}
---

<MainLayout>
  {page.pageBuilder && <BlockRenderer blocks={page.pageBuilder} />}
</MainLayout>
