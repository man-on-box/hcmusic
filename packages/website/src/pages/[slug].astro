---
import MainLayout from "../layouts/main.astro";
import BlockRenderer from "../blocks/block-renderer.astro";
import { resolvePagesData, resolvePageData } from "../sanity/resolvers";

export async function getStaticPaths() {
  const data = await resolvePagesData();
  return data.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}
const { slug } = Astro.params;
const { page: initialData } = Astro.props;

const page = initialData ?? (await resolvePageData(Astro.cookies, slug));
const { pageBuilder, title, seo } = page;
---

<MainLayout title={title} seo={seo}>
  {pageBuilder && <BlockRenderer blocks={pageBuilder} />}
</MainLayout>
