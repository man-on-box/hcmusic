---
import { PortableText } from "astro-portabletext";

import { pageQuery } from "../sanity/queries";
import { urlFor } from "../sanity/image";
import MainLayout from "../layouts/main.astro";
import Hero from "../components/hero.astro";
import BlockRenderer from "../blocks/block-renderer.astro";
import Prose from "../components/prose.astro";

export async function getStaticPaths() {
  const pages = await pageQuery();

  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---

<MainLayout>
  <Hero
    heading={page.heading ?? "Default heading"}
    subheading={page.subheading}
    imgSrc={page.image
      ? urlFor(page.image).width(1200).height(300).format("webp").url()
      : ""}
    imgAlt={page.image?.alt || ""}
  />
  <section class="flex flex-col items-center py-16">
    <Prose class="w-full">
      {page?.content && <PortableText value={page.content} />}
    </Prose>
  </section>
  {page.pageBuilder && <BlockRenderer blocks={page.pageBuilder} />}
</MainLayout>
