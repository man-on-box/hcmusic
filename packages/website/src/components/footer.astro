---
import type { LinkType } from "../types/sanity";
import { linkResolver } from "../utils/link-resolver";

interface Props {
  siteName: string;
  siteTagline: string;
  navItems: { label: string; link: LinkType | null }[];
}

const { siteName, siteTagline, navItems = [] } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="flex flex-col gap-2 border-l-4 border-l-slate-500">
    <div class="border-t border-gray-300"></div>
    <div class="border-t border-gray-300"></div>
    <div class="border-t border-gray-300"></div>
    <div class="border-t border-gray-300"></div>
    <div class="border-t border-gray-300"></div>
  </div>
  <div class="bg-white px-6 py-18 lg:px-8">
    <div
      class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-6 md:flex-row"
    >
      <div class="text-center md:text-left">
        <a
          href="/"
          class="text-foreground font-serif text-lg tracking-wide uppercase"
          >{siteName}</a
        ><p class="mt-2 text-xs text-gray-500">
          {siteTagline}
        </p>
      </div><nav class="flex flex-wrap justify-center gap-6">
        {
          navItems.map(({ label, link }) => (
            <a
              class="text-xs tracking-wide text-gray-500 transition-colors hover:text-black"
              href={linkResolver(link).href}
            >
              {label}
            </a>
          ))
        }
      </nav><p class="text-xs text-gray-500">© {currentYear}</p>
    </div>
  </div>
</footer>
