---
import { cn } from "../utils";
import type { LinkType } from "../types/sanity";
import { linkResolver } from "../utils/link-resolver";

interface Props {
  siteName: string;
  navItems: { label: string; link: LinkType | null }[];
}

const path = Astro.url.pathname;
const isActive = (href: string) => {
  return path.startsWith(href);
};

const { siteName, navItems = [] } = Astro.props;
---

<header
  class="sticky top-0 z-50 border-b border-gray-300 bg-white/90 backdrop-blur-sm"
>
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8"
  >
    <a class="flex items-center gap-2" href="/"
      ><span class="text-foreground font-serif text-lg text-slate-900 uppercase"
        >{siteName}</span
      ></a
    >
    <div class="group hidden md:flex md:gap-x-4">
      {
        navItems.map(({ link, label }) => {
          const { href } = linkResolver(link);
          return (
            <a
              class={cn(
                "rounded px-2 py-1 text-sm tracking-wide text-slate-600 transition-colors group-hover:text-slate-500 hover:bg-slate-500/10 hover:text-slate-900",
                isActive(href) && "bg-slate-400/10 text-slate-900",
              )}
              href={href}
            >
              {label}
            </a>
          );
        })
      }
    </div>
    <button
      id="nav-toggle"
      type="button"
      class="-m-2 p-2 md:hidden"
      aria-label="Open menu"
      ><svg
        id="menu-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="size-5"
        aria-hidden="true"
        ><path d="M4 5h16"></path><path d="M4 12h16"></path><path d="M4 19h16"
        ></path></svg
      >
      <svg
        id="close-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="hidden size-5"
        aria-hidden="true"
        ><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
      >
    </button>
  </nav>
  <div
    id="mobile-menu"
    class="hidden border-t border-gray-100 bg-white md:hidden"
  >
    <div class="flex flex-col gap-4 px-8 py-8">
      {
        navItems.map(({ link, label }) => (
          <a
            class="py-4 tracking-wide text-slate-600"
            href={linkResolver(link).href}
          >
            {label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const navToggle = document.getElementById("nav-toggle")!;
    const menuIcon = document.getElementById("menu-icon")!;
    const closeIcon = document.getElementById("close-icon")!;
    const mobileMenu = document.getElementById("mobile-menu")!;

    let state: "open" | "closed" = "closed";

    const openMenu = () => {
      menuIcon.classList.add("hidden");
      closeIcon.classList.remove("hidden");
      mobileMenu.classList.remove("hidden");
      navToggle.ariaLabel = "Close menu";
      state = "open";
    };

    const closeMenu = () => {
      menuIcon.classList.remove("hidden");
      closeIcon.classList.add("hidden");
      mobileMenu.classList.add("hidden");
      navToggle.ariaLabel = "Open menu";
      state = "closed";
    };

    navToggle.addEventListener("click", () => {
      if (state === "closed") {
        openMenu();
        return;
      }
      closeMenu();
    });
  });
</script>
