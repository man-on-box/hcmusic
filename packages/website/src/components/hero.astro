---
import { Image } from "astro:assets";
import { cn } from "../utils";

interface Props {
  heading: string;
  subheading?: string | null;
  imgSrc: string;
  imgAlt: string;
  variant?: "small" | "large";
}

const { heading, subheading, imgSrc, imgAlt, variant = "small" } = Astro.props;

const variants = {
  small: {
    imgHeight: 500,
    container: "h-[30vh] min-h-[300px]",
    textBox: "px-8 py-6 md:px-12 md:py-6",
    heading: "text-3xl md:text-4xl lg:text-5xl",
  },
  large: {
    imgHeight: 900,
    container: "h-[50vh] min-h-[500px]",
    textBox: "px-10 py-8 md:px-16 md:py-12",
    heading: "text-5xl md:text-6xl lg:text-7xl",
  },
};

const style = variants[variant];
---

<section class={cn("relative w-full bg-slate-900", style.container)}>
  {
    imgSrc && (
      <Image
        src={imgSrc}
        alt={imgAlt}
        width={1600}
        height={style.imgHeight}
        priority={true}
        layout="full-width"
        class="aspect-video h-full w-full object-cover"
      />
    )
  }
  <div
    class="absolute inset-0 mx-auto flex max-w-7xl items-center justify-start"
  >
    <div
      class={cn(
        "rounded-xs bg-slate-900/80 text-left backdrop-blur-xs mr-10",
        style.textBox,
      )}
    >
      <h1
        class={cn(
          "font-serif text-4xl tracking-wide text-white uppercase",
          style.heading,
        )}
      >
        {heading}
      </h1>
      {
        subheading && (
          <p class="mt-3 text-sm font-light tracking-widest text-balance text-white/80 uppercase md:text-lg">
            {subheading}
          </p>
        )
      }
    </div>
  </div>
</section>
