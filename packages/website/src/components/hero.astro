---
interface Props {
  heading: string;
  subheading: string;
  imgSrc: string;
  imgAlt: string;
}

const { heading, subheading, imgSrc, imgAlt } = Astro.props;
---

<section class="relative h-[70vh] min-h-[500px] w-full">
  <img src={imgSrc} alt={imgAlt} class="h-full w-full object-cover" />
  <div
    class="absolute inset-0 flex items-center justify-start px-6 md:px-12 lg:px-24"
  >
    <div
      class="ml-[5%] rounded-xs bg-gray-900/80 px-10 py-8 text-left backdrop-blur-xs md:ml-[10%] md:px-16 md:py-12"
    >
      <h1
        class="text-4xl tracking-wide text-white uppercase sm:text-5xl md:text-6xl lg:text-7xl"
      >
        {heading}
      </h1>
      <p
        class="mt-3 text-base font-light tracking-widest text-white/90 uppercase md:text-lg lg:text-xl"
      >
        {subheading}
      </p>
    </div>
  </div>
</section>
