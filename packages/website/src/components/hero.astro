---
import { Image } from "astro:assets";
import { cn } from "../utils";

interface Props {
  heading: string;
  subheading?: string | null;
  imgSrc: string;
  imgAlt: string;
  variant?: "small" | "large";
}

const { heading, subheading, imgSrc, imgAlt, variant = "small" } = Astro.props;

const variants = {
  small: {
    imgHeight: 300,
    container: "h-[35vh] min-h-[250px]",
    textBox: "px-8 py-6 md:px-12 md:py-6",
    heading: "text-3xl md:text-4xl lg:text-5xl",
  },
  large: {
    imgHeight: 900,
    container: "h-[70vh] min-h-[500px]",
    textBox: "px-10 py-8 md:px-16 md:py-12",
    heading: "text-5xl md:text-6xl lg:text-7xl",
  },
};

const style = variants[variant];
---

<section class={cn("relative w-full bg-gray-900", style.container)}>
  {
    imgSrc && (
      <Image
        src={imgSrc}
        alt={imgAlt}
        width={1600}
        height={style.imgHeight}
        loading="eager"
        class="h-full w-full object-cover"
      />
    )
  }
  <div
    class="absolute inset-0 flex items-center justify-start px-6 md:px-12 lg:px-24"
  >
    <div
      class={cn(
        "ml-[5%] rounded-xs bg-gray-900/80 text-left backdrop-blur-xs md:ml-[10%]",
        style.textBox,
      )}
    >
      <h1
        class={cn("text-4xl tracking-wide text-white uppercase", style.heading)}
      >
        {heading}
      </h1>
      {
        subheading && (
          <p class="mt-3 text-base font-light tracking-widest text-white/90 uppercase md:text-lg lg:text-xl">
            {subheading}
          </p>
        )
      }
    </div>
  </div>
</section>
