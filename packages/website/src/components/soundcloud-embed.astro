---
interface Props {
  songUrl?: string;
  label?: string;
  node?: {
    songUrl: string;
    id: string;
  };
}

const { node, songUrl } = Astro.props;

const soundcloudSongUrl = node?.songUrl || songUrl || "";
const embedUrl = `https://w.soundcloud.com/player/?url=${encodeURIComponent(soundcloudSongUrl)}&color=%230f172b&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true`;
---

<div class="my-4">
  <iframe height="166" allow="autoplay" src={embedUrl}></iframe>
</div>
