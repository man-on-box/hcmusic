---
interface Props {
  songUrl?: string;
  label?: string;
  node?: {
    songUrl: string;
    id: string;
  };
}

const { node, songUrl } = Astro.props;

const baseEmbedUrl = `https://w.soundcloud.com/player/?auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true`;
const playerColor = "#0f172b";
const soundcloudSongUrl = node?.songUrl || songUrl || "";

const embedUrl = new URL(baseEmbedUrl);
embedUrl.searchParams.set("url", soundcloudSongUrl);
embedUrl.searchParams.set("color", playerColor);
---

<div class="my-4">
  <iframe class="w-full" height="166" allow="autoplay" src={embedUrl.toString()}
  ></iframe>
</div>
