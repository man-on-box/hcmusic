---
import { PortableText } from "astro-portabletext";
import type { PortableTextBlock } from "@portabletext/types";

import { formatTime, formatDate } from "../utils";
import Prose from "../components/prose.astro";

type Event = {
  title: string;
  date: string;
  location: string;
  description: PortableTextBlock[] | null;
};

interface Props {
  heading: string;
  events: Event[];
}

const { heading, events } = Astro.props;

const currentDate = new Date();
const currentYear = currentDate.getFullYear();
---

<div class="mx-auto my-20 flex max-w-6xl flex-col px-6 md:my-26 md:px-12">
  <Prose>
    <h2>{heading}</h2>
  </Prose>
  <ol class="mt-20">
    {
      events.map((event) => {
        const date = new Date(event.date || Date.now());

        const { day, month, hour, minute, year } = formatDate(date);

        const isFuture = date >= currentDate;

        return (
          <li class="flex gap-4 border-t-1 border-slate-200 py-4 last:border-b-1 md:gap-8">
            <div class="flex size-16 shrink-0 flex-col items-center justify-center rounded bg-slate-100 p-4 font-serif sm:size-21">
              <p class="text-xl font-bold sm:text-3xl">{day}</p>
              <p class="sm:text-xl">{month}</p>
            </div>
            <div>
              <p class="font-bold text-gray-800">
                {year !== String(currentYear) && `${year} · `}
                {event.title}
              </p>
              <p class="text-sm text-gray-600">
                {isFuture && `${hour}:${minute} · `}
                {event.location}
              </p>
              {event.description && (
                <Prose class="mt-2 text-gray-600">
                  <PortableText value={event.description} />
                </Prose>
              )}
            </div>
          </li>
        );
      })
    }
  </ol>
</div>
