---
import { Image } from "astro:assets";
import { urlFor } from "../sanity/image";
import Prose from "../components/prose.astro";
import { formatDate } from "../utils";
import type { BlogArticleCardData } from "../types/sanity";

interface Props {
  article: BlogArticleCardData;
}

const IMAGE_SIZE_PX = 700;

const { article } = Astro.props;
const { title, description, articleDate, featureImage } = article;
const date = new Date(articleDate ?? "");
const formattedDate = formatDate(date);
---

<div
  class="flx-c flex flex-col gap-8 border-t-1 border-slate-200 py-12 first:border-t-0 last:border-b-1 sm:flex-row sm:py-6"
>
  {
    featureImage ? (
      <Image
        src={urlFor(featureImage)
          .width(IMAGE_SIZE_PX * 1.5)
          .height((IMAGE_SIZE_PX / 2) * 1.5)
          .format("webp")
          .url()}
        width={IMAGE_SIZE_PX}
        height={IMAGE_SIZE_PX / 2}
        alt={featureImage.asset?.altText || ""}
        layout="full-width"
        class="h-60 w-full shrink-0 rounded object-cover sm:size-60"
      />
    ) : (
      <div class="empty-image hidden size-60 shrink-0 flex-col items-center justify-center rounded bg-slate-100 sm:flex" />
    )
  }
  <div>
    <h2 class="text-xl font-bold text-gray-800">
      {title}
    </h2>
    <p class="text-sm text-gray-600">
      {formattedDate.day}
      {formattedDate.month}
      {formattedDate.year}
    </p>
    {description && <Prose class="mt-4 text-gray-600">{description}</Prose>}
  </div>
</div>

<style>
  .empty-image {
    background-image: url("data:image/svg+xml,%3Csvg width='52' height='26' viewBox='0 0 52 26' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%230f172b' fill-opacity='0.2'%3E%3Cpath d='M10 10c0-2.21-1.79-4-4-4-3.314 0-6-2.686-6-6h2c0 2.21 1.79 4 4 4 3.314 0 6 2.686 6 6 0 2.21 1.79 4 4 4 3.314 0 6 2.686 6 6 0 2.21 1.79 4 4 4v2c-3.314 0-6-2.686-6-6 0-2.21-1.79-4-4-4-3.314 0-6-2.686-6-6zm25.464-1.95l8.486 8.486-1.414 1.414-8.486-8.486 1.414-1.414z' /%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
</style>
