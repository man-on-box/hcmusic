---
import type { LinkType } from "../types/sanity";
import { linkResolver } from "../utils/link-resolver";

type MarkDef = LinkType & {
  _key: string;
  _type: "textLink";
};

interface Props {
  node: {
    markDef: MarkDef;
  };
}

const props = Astro.props;
const { _key, _type, ...link } = props.node.markDef;

const { href, linkType } = linkResolver(link);
const isExternal = linkType === "external";
---

<a
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener noreferrer" : undefined}><slot /></a
>
