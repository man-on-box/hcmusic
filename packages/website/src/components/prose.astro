---
import { cn } from "../utils";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class={cn(
    "text-balance prose prose-h2:font-serif prose-h3:font-serif prose-h2:tracking-wide prose-h3:tracking-wide prose-h2:font-light prose-h3:font-light md:prose-h2:text-5xl prose-h2:text-4xl prose-h3:text-3xl prose-a:text-slate-800 prose-a:underline prose-img:rounded-xs",
    className,
  )}
>
  <slot />
</div>
