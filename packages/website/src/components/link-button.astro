---
import { cn } from "../utils";

interface Props {
  href: string;
  class?: string;
}

const { href, class: className } = Astro.props;
---

<a
  class={cn(
    "font-semibold rounded bg-slate-700 hover:bg-slate-800 transition-colors px-5 py-2 text-white",
    className,
  )}
  href={href}><slot /></a
>
