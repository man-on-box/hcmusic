---
import { cn } from "../utils";

interface Props {
  href: string;
  class?: string;
}

const { href, class: className } = Astro.props;
---

<a
  class={cn(
    "font-serif font-normal tracking-wider hover:rounded border-y border-slate-700 text-slate-700 hover:bg-slate-800 transition-colors px-5 py-2 hover:text-white",
    className,
  )}
  href={href}><slot /></a
>
