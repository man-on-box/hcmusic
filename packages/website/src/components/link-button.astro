---
import type { LinkType } from "../types/sanity";
import { linkResolver } from "../utils/link-resolver";
import { cn } from "../utils";

interface Props {
  link: LinkType | null;
  class?: string;
}

const { class: className, link } = Astro.props;

const { href } = linkResolver(link);
---

<a
  class={cn(
    "font-serif font-normal tracking-wider hover:rounded border-y border-slate-700 text-slate-700 hover:bg-slate-800 transition-colors px-5 py-2 hover:text-white",
    className,
  )}
  href={href}><slot /></a
>
