---
import { Image } from "astro:assets";
import { stegaClean } from "@sanity/client/stega";

import { cn } from "../utils";
import { urlFor } from "../sanity/image";
import Prose from "../components/prose.astro";
import type { FeatureCardsBlockData } from "../types/sanity";
import { linkResolver } from "../utils/link-resolver";

interface Props {
  blockData: FeatureCardsBlockData;
}

const { blockData } = Astro.props;
const { heading, cards, background } = blockData;

const IMAGE_SIZE_PX = 500;

const variants = {
  dark: {
    container: "bg-slate-800",
    heading: "prose-invert",
  },
  light: {
    container: "bg-white",
    heading: "",
  },
};

const styles = variants[stegaClean(background) || "light"];
---

<section class={cn("py-18 md:py-22", styles.container)}>
  <div class="mx-auto max-w-7xl">
    <Prose class={cn("mx-auto text-center", styles.heading)}>
      <h2>{heading}</h2>
    </Prose>
    <div
      class="mx-auto mt-16 grid max-w-6xl gap-8 px-4 md:grid-cols-3 md:gap-4 lg:gap-10 xl:px-0"
    >
      {
        cards?.map((card) => {
          return (
            <a
              href={linkResolver(card.link).href}
              class="group flex flex-col rounded bg-white/95 shadow-xl transition-colors hover:bg-white"
            >
              {card.cardImage && (
                <Image
                  src={urlFor(card.cardImage)
                    .width(IMAGE_SIZE_PX * 1.5)
                    .height((IMAGE_SIZE_PX / 2) * 1.5)
                    .format("webp")
                    .url()}
                  width={IMAGE_SIZE_PX}
                  height={IMAGE_SIZE_PX / 2}
                  alt={card.cardImage.asset?.altText || ""}
                  layout="full-width"
                  class="h-54 w-full shrink-0 rounded-t object-cover"
                />
              )}
              <div class="flex h-full flex-col justify-between gap-5 p-5">
                <Prose>
                  <h3>{card.title}</h3>
                  <p class="text-slate-600">{card.description}</p>
                </Prose>
                <span class="font-serif text-lg tracking-wide text-slate-800 group-hover:underline">
                  Learn more
                </span>
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</section>
