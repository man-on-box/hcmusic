---
import { PortableText } from "astro-portabletext";
import { cn } from "../utils";

import Prose from "../components/prose.astro";
import type { TextBlock } from "../sanity/sanity.types";

interface Props {
  blockData: TextBlock;
}

const { blockData } = Astro.props;

const textAlignClassMap: Record<NonNullable<TextBlock["textAlign"]>, string> = {
  left: "prose-p:text-left prose-h2:text-left prose-h3:text-left",
  center: "prose-p:text-center prose-h2:text-center prose-h3:text-center",
  justify: "prose-p:text-justify prose-h2:text-center prose-h3:text-center",
};

const textAlign = textAlignClassMap[blockData.textAlign || "left"];
---

<section class="flex flex-col items-center py-16">
  <Prose class={cn("w-full", textAlign)}>
    {blockData?.content && <PortableText value={blockData.content} />}
  </Prose>
</section>
