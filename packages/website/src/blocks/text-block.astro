---
import { Image } from "astro:assets";
import { PortableText } from "astro-portabletext";
import { cn } from "../utils";

import Section from "../components/section.astro";
import YoutubeEmbed from "../components/youtube-embed.astro";
import SoundcloudEmbed from "../components/soundcloud-embed.astro";
import MailchimpForm from "../components/mailchimp-form.astro";
import LinkButton from "../components/link-button.astro";
import Prose from "../components/prose.astro";
import TextLink from "../components/text-link.astro";

import type { TextBlockData } from "../types/sanity";
import { urlFor } from "../sanity/image";
import { stegaClean } from "@sanity/client/stega";

interface Props {
  blockData: TextBlockData;
}

const { blockData } = Astro.props;
const {
  content,
  cta,
  ctaLink,
  leadInText,
  textAlign,
  featureImage,
  imageAlign,
  sectionId,
} = blockData;

const textAlignClassMap: Record<
  NonNullable<TextBlockData["textAlign"]>,
  string
> = {
  left: "prose-p:text-left prose-h2:text-left prose-h3:text-left",
  center: "prose-p:text-center prose-h2:text-center prose-h3:text-center",
  justify: "prose-p:text-justify prose-h2:text-center prose-h3:text-center",
};

const leadInStyles =
  "first-letter:text-8xl first-letter:float-left first-letter:mr-2 first-line:font-serif first-line:tracking-wider first-line:text-2xl first-line:text-slate-800";

const textAlignStyles = textAlignClassMap[stegaClean(textAlign) || "left"];

const imageSize = 500;

const components = {
  mark: {
    textLink: TextLink,
  },
  type: {
    youtube: YoutubeEmbed,
    soundcloud: SoundcloudEmbed,
    mailchimpForm: MailchimpForm,
  },
};
---

<Section id={sectionId ?? undefined}>
  <div
    class={cn(
      "mx-auto flex flex-col-reverse gap-12 sm:flex-row items-center sm:items-start",
      stegaClean(imageAlign) === "right" && "sm:flex-row-reverse",
    )}
  >
    {
      featureImage && (
        <div class="grow-1">
          <Image
            src={urlFor(featureImage)
              .width(imageSize * 1.5)
              .height(imageSize * 1.5)
              .format("webp")
              .url()}
            width={imageSize}
            height={imageSize}
            alt={featureImage.asset?.altText || ""}
            layout="constrained"
            class="rounded object-contain"
          />
        </div>
      )
    }
    <div class="flex grow-1 flex-col">
      <Prose class={cn("min-w-0", textAlignStyles, leadInText && leadInStyles)}>
        {content && <PortableText value={content} components={components} />}
      </Prose>
      {
        cta && ctaLink && (
          <div class="mt-12 flex justify-center">
            <LinkButton link={ctaLink}>{cta}</LinkButton>
          </div>
        )
      }
    </div>
  </div>
</Section>
