---
import { Image } from "astro:assets";
import { PortableText } from "astro-portabletext";
import { cn } from "../utils";

import LinkButton from "../components/link-button.astro";
import Prose from "../components/prose.astro";
import type { TextBlockData } from "../types/sanity";
import { urlFor } from "../sanity/image";

interface Props {
  blockData: TextBlockData;
}

const { blockData } = Astro.props;
const {
  content,
  cta,
  ctaPath,
  leadInText,
  textAlign,
  featureImage,
  imageAlign,
  sectionId,
} = blockData;

const textAlignClassMap: Record<
  NonNullable<TextBlockData["textAlign"]>,
  string
> = {
  left: "prose-p:text-left prose-h2:text-left prose-h3:text-left",
  center: "prose-p:text-center prose-h2:text-center prose-h3:text-center",
  justify: "prose-p:text-justify prose-h2:text-center prose-h3:text-center",
};

const leadInStyles =
  "first-letter:text-8xl first-letter:float-left first-letter:mr-2 first-line:font-serif first-line:tracking-wider first-line:text-2xl first-line:text-slate-800";

const textAlignStyles = textAlignClassMap[textAlign || "left"];

const imageSize = 500;
---

<section
  id={sectionId ?? undefined}
  class="mx-auto flex max-w-6xl flex-col items-center px-6 py-18 md:px-12 md:py-22"
>
  <div
    class={cn(
      "flex flex-col gap-8 sm:flex-row md:gap-12 items-start",
      imageAlign === "right" && "sm:flex-row-reverse",
    )}
  >
    {
      featureImage && (
        <Image
          src={urlFor(featureImage)
            .width(imageSize * 1.5)
            .height(imageSize * 1.5)
            .format("webp")
            .url()}
          width={imageSize}
          height={imageSize}
          alt={featureImage.alt || ""}
          layout="constrained"
          class="h-full w-full rounded object-contain sm:h-70 md:h-full"
        />
      )
    }
    <Prose class={cn("w-full", textAlignStyles, leadInText && leadInStyles)}>
      {content && <PortableText value={content} />}
    </Prose>
  </div>
  {
    cta && ctaPath && (
      <LinkButton class="mt-12" href={ctaPath}>
        {cta}
      </LinkButton>
    )
  }
</section>
