---
import { urlFor } from "../sanity/image";
import Hero from "../components/hero.astro";
import type { HeroBlockData } from "../types/sanity";

interface Props {
  blockData: HeroBlockData;
}

const { blockData } = Astro.props;
---

<Hero
  heading={blockData.heading ?? "Default heading"}
  subheading={blockData.subtitle}
  variant={blockData.size || "small"}
  imgSrc={blockData.backgroundImage
    ? urlFor(blockData.backgroundImage)
        .width(1200)
        .height(900)
        .format("webp")
        .url()
    : ""}
  imgAlt={blockData.backgroundImage?.asset?.altText || ""}
/>
