---
import HeroBlock from "./hero-block.astro";
import TextBlock from "./text-block.astro";
import FeatureCardsBlock from "./feature-cards-block.astro";

import type { PageData } from "../types/sanity";
type Blocks = NonNullable<PageData["pageBuilder"]>;
type BlockTypeNames = Blocks[number]["_type"];

interface Props {
  blocks: Blocks;
}

const componentMap: Record<BlockTypeNames, any> = {
  heroBlock: HeroBlock,
  textBlock: TextBlock,
  featureCardsBlock: FeatureCardsBlock,
};

const { blocks } = Astro.props;
---

<>
  {
    blocks.map((block) => {
      const Section = componentMap[block._type];

      if (!Section) {
        return <p>Missing block for type: {block._type}</p>;
      }

      return <Section blockData={block} />;
    })
  }
</>
